# Copy to .env and fill in. All values are read at startup by src/kalshi_weather/config.py.

# Contact email embedded in the User-Agent header — NWS requires identifying contact info
# on every request (format: "APP_NAME (email)").
NWS_CONTACT_EMAIL=you@example.com

# App name for the User-Agent header.
APP_NAME=kalshi-weather

# Where the DuckDB database file lives. Relative paths resolve against the repo root.
DUCKDB_PATH=data/weather.duckdb
